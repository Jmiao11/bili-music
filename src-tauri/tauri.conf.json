{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bili Music",
  "version": "0.1.0",
  "identifier": "com.bili.music",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Bili Music",
        "width": 1180,
        "height": 760,
        "minWidth": 1080,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [],
    "externalBin": []
  }
}
